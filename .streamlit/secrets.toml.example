# ──────────────────────────────────────────────────────────────────────────────
# Streamlit secrets template
# ──────────────────────────────────────────────────────────────────────────────
# LOCAL: copy this file to .streamlit/secrets.toml and fill in your keys.
# CLOUD: paste these key-value pairs into Settings > Secrets on Streamlit Cloud.
#
# All values are optional — leave blank or remove lines you don't need.
# The app reads secrets with config.get_secret(), which checks st.secrets
# first and falls back to environment variables.
# ──────────────────────────────────────────────────────────────────────────────

# --- LLM providers -----------------------------------------------------------

# OpenRouter (recommended default — access to many models)
OPENROUTER_API_KEY = ""

# OpenAI direct
OPENAI_API_KEY = ""
# OPENAI_BASE_URL = "https://api.openai.com/v1"   # uncomment to override

# Alibaba Cloud Model Studio / Qwen
# API keys are region-specific — HK, Singapore, US, Beijing keys are NOT interchangeable.
# The base URL must match the key's region.
# See: https://www.alibabacloud.com/help/en/model-studio/regions/
DASHSCOPE_API_KEY = ""
# DASHSCOPE_BASE_URL = "https://cn-hongkong.dashscope.aliyuncs.com/compatible-mode/v1"

# --- News --------------------------------------------------------------------

# GNews API key (https://gnews.io/) — enables richer news coverage.
# Without it the app falls back to yfinance headlines + web scraping.
GNEWS_API_KEY = ""
