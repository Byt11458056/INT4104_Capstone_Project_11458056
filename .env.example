# Copy this file to .env and fill in your API keys.

# GNews API key (optional — enables richer news coverage)
GNEWS_API_KEY=

# Optional: shared web search backend for centralized news/web research
# Supported values today: ddgs, google, auto
WEB_SEARCH_PROVIDER=auto

# OpenRouter API key (primary LLM provider)
OPENROUTER_API_KEY=

# Alibaba Cloud Model Studio (Qwen) — OpenAI-compatible mode
# Get a key: https://www.alibabacloud.com/help/en/model-studio/first-api-call-to-qwen
# IMPORTANT: API keys are region-specific and NOT interchangeable.
DASHSCOPE_API_KEY=
# Optional: force endpoint if not using the sidebar region selector in Docker
# Hong Kong (China)   — default:
# DASHSCOPE_BASE_URL=https://cn-hongkong.dashscope.aliyuncs.com/compatible-mode/v1
# Singapore / International:
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# US (Virginia):
# DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
# China (Beijing):
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
